{
  "name": "guzeltenknoloji-cms",
  "version": "0.5.0",
  "private": true,
  "description": "Multi-tenant kurumsal web sitesi CMS",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "build": "npm run build --workspace=backend && npm run build --workspace=frontend",
    "db:push": "npm run db:push --workspace=backend",
    "db:generate": "npm run db:generate --workspace=backend",
    "setup": "npm install && npm run db:setup",
    "db:setup": "npm run db:setup --workspace=backend",
    "postpull": "npm install && npm run db:push && npm run db:generate",
    "db:seed": "npm run db:seed --workspace=backend",
    "db:temizle": "npm run db:temizle --workspace=backend"
  },
  "workspaces": [
    "frontend",
    "backend"
  ],
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
